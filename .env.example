# 本文件只声明可公开的运行配置，不要在这里填写任何密钥。
CANVAS_REGISTRATION_ENABLED=false
CANVAS_ALLOW_PRIVATE_UPSTREAMS=false
CANVAS_ALLOWED_PRIVATE_UPSTREAM_HOSTS=
CANVAS_CORS_ORIGINS=http://localhost:3000
CANVAS_DATA_PATH=./data

# 新服务器请直接运行 README 的一键部署命令；脚本会在 .env 中生成以下 PostgreSQL 配置。
# POSTGRES_DB=open_ai_canvas
# POSTGRES_USER=open_ai_canvas
# POSTGRES_PASSWORD=由部署脚本随机生成
# DATABASE_URL=postgresql://open_ai_canvas:随机密码@postgres:5432/open_ai_canvas?sslmode=disable
# REDIS_URL=redis://redis:6379/0
# CANVAS_POSTGRES_DATA_PATH=./postgres-data
# CANVAS_REDIS_DATA_PATH=./redis-data
# CANVAS_HTTP_PORT=3000
